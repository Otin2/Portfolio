---
import { site, translations, defaultLang } from '../data.js'

const { contact } = translations[defaultLang]
const { email, phone, socials, profile } = site

// Fondo de destellos con curvas
const beamPath = (i) =>
  `M${-380 + 7 * i} ${-189 - 8 * i}C${-380 + 7 * i} ${-189 - 8 * i} ${-312 + 7 * i} ${216 - 8 * i} ` +
  `${152 + 7 * i} ${343 - 8 * i}C${616 + 7 * i} ${470 - 8 * i} ${684 + 7 * i} ${875 - 8 * i} ` +
  `${684 + 7 * i} ${875 - 8 * i}`

const beams = Array.from({ length: 14 }, (_, i) => ({
  d: beamPath(i * 4 - 10),
  dur: (Math.random() * 10 + 10).toFixed(2),
  delay: (Math.random() * 10).toFixed(2),
  y2End: (93 + Math.random() * 8).toFixed(2),
}))

const staticOffsets = Array.from({ length: 90 }, (_, i) => i + 1)
---

<section id="contacto" class="section section--contact reveal">
  <div class="container">
    <div class="contact-card">
      <div class="contact-beams" aria-hidden="true">
        <svg width="100%" height="100%" viewBox="0 0 696 316" fill="none" xmlns="http://www.w3.org/2000/svg">
          <g class="contact-beams__static" stroke-width="0.5">
            <path id="beam-base" d={beamPath(-25)}></path>
            {staticOffsets.map((k) => <use href="#beam-base" x={7 * k} y={-8 * k} />)}
          </g>
          <g class="contact-beams__animated">
            {beams.map((beam, i) => (
              <path d={beam.d} stroke={`url(#beam-grad-${i})`} stroke-opacity="0.4" stroke-width="1"></path>
            ))}
          </g>
          <defs>
            {beams.map((beam, i) => (
              <linearGradient id={`beam-grad-${i}`} x1="0%" x2="0%" y1="0%" y2="0%">
                <animate attributeName="x1" values="0%;100%" dur={`${beam.dur}s`} begin={`${beam.delay}s`} repeatCount="indefinite" calcMode="spline" keySplines="0.42 0 0.58 1" keyTimes="0;1" />
                <animate attributeName="x2" values="0%;95%" dur={`${beam.dur}s`} begin={`${beam.delay}s`} repeatCount="indefinite" calcMode="spline" keySplines="0.42 0 0.58 1" keyTimes="0;1" />
                <animate attributeName="y1" values="0%;100%" dur={`${beam.dur}s`} begin={`${beam.delay}s`} repeatCount="indefinite" calcMode="spline" keySplines="0.42 0 0.58 1" keyTimes="0;1" />
                <animate attributeName="y2" values={`0%;${beam.y2End}%`} dur={`${beam.dur}s`} begin={`${beam.delay}s`} repeatCount="indefinite" calcMode="spline" keySplines="0.42 0 0.58 1" keyTimes="0;1" />
                <stop class="beam-stop-a" stop-opacity="0"></stop>
                <stop class="beam-stop-a"></stop>
                <stop offset="32.5%" class="beam-stop-b"></stop>
                <stop offset="100%" class="beam-stop-c" stop-opacity="0"></stop>
              </linearGradient>
            ))}
          </defs>
        </svg>
      </div>

      <header class="contact__head">
        <h2 class="contact__title" data-i18n="contact.heading">{contact.heading}</h2>
        <p class="contact__text" data-i18n="contact.text">{contact.text}</p>
      </header>

      <div class="contact__grid">
        <div class="contact-info">
          <h3 class="contact-info__title" data-i18n="contact.infoTitle">{contact.infoTitle}</h3>
          <p class="contact-info__text" data-i18n="contact.infoText">{contact.infoText}</p>

          <ul class="contact-info__list">
            <li class="contact-info__item">
              <span class="contact-info__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
              </span>
              <div>
                <span class="contact-info__label" data-i18n="contact.labels.email">{contact.labels.email}</span>
                <a class="contact-info__value" href={`mailto:${email}`}>{email}</a>
              </div>
            </li>
            <li class="contact-info__item">
              <span class="contact-info__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </span>
              <div>
                <span class="contact-info__label" data-i18n="contact.labels.phone">{contact.labels.phone}</span>
                <span class="contact-info__value">{phone}</span>
              </div>
            </li>
            <li class="contact-info__item">
              <span class="contact-info__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              </span>
              <div>
                <span class="contact-info__label" data-i18n="contact.labels.location">{contact.labels.location}</span>
                <span class="contact-info__value">{profile.location}</span>
              </div>
            </li>
          </ul>

          <h3 class="contact-info__title" data-i18n="contact.connectTitle">{contact.connectTitle}</h3>
          <div class="contact-info__socials">
            <a class="contact-social" href={socials.github} target="_blank" rel="noreferrer" aria-label="GitHub">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            </a>
            <a class="contact-social" href={socials.linkedin} target="_blank" rel="noreferrer" aria-label="LinkedIn">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6Z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            <a class="contact-social" href={`mailto:${email}`} aria-label="Email">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
            </a>
          </div>
        </div>

        <form class="contact-form" novalidate>
          <div class="contact-form__row">
            <div class="contact-form__field">
              <label for="contact-name" data-i18n="contact.form.name">{contact.form.name}</label>
              <input
                id="contact-name"
                name="name"
                type="text"
                placeholder={contact.form.namePh}
                data-i18n-placeholder="contact.form.namePh"
                autocomplete="name"
              />
            </div>
            <div class="contact-form__field">
              <label for="contact-email" data-i18n="contact.form.email">{contact.form.email}</label>
              <input
                id="contact-email"
                name="email"
                type="email"
                placeholder={contact.form.emailPh}
                data-i18n-placeholder="contact.form.emailPh"
                autocomplete="email"
              />
            </div>
          </div>
          <div class="contact-form__field">
            <label for="contact-subject" data-i18n="contact.form.subject">{contact.form.subject}</label>
            <input
              id="contact-subject"
              name="subject"
              type="text"
              placeholder={contact.form.subjectPh}
              data-i18n-placeholder="contact.form.subjectPh"
            />
          </div>
          <div class="contact-form__field">
            <label for="contact-message" data-i18n="contact.form.message">{contact.form.message}</label>
            <textarea
              id="contact-message"
              name="message"
              rows="3"
              placeholder={contact.form.messagePh}
              data-i18n-placeholder="contact.form.messagePh"></textarea>
          </div>
          <input type="checkbox" name="botcheck" class="contact-form__botcheck" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <button class="btn btn--primary contact-form__send" type="submit">
            <span class="contact-form__spinner" aria-hidden="true"></span>
            <span class="contact-form__send-label" data-i18n="contact.form.send">{contact.form.send}</span>
          </button>
          <p class="contact-form__status" role="status" hidden>
            <svg class="contact-form__status-icon contact-form__status-icon--ok" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="m8.5 12.5 2.5 2.5 4.5-5.5"/></svg>
            <svg class="contact-form__status-icon contact-form__status-icon--err" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
            <span class="contact-form__status-text"></span>
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  import { site, translations, defaultLang } from '../data.js'

  // Envio del formulario con EmailJS
  const form = document.querySelector('.contact-form')
  const status = form?.querySelector('.contact-form__status')
  const statusText = status?.querySelector('.contact-form__status-text')
  const sendBtn = form?.querySelector('.contact-form__send')
  const sendLabel = sendBtn?.querySelector('.contact-form__send-label')

  const formText = (key) => {
    const lang = document.documentElement.lang || defaultLang
    const dict = translations[lang] || translations[defaultLang]
    return dict.contact.form[key]
  }

  const showStatus = (key, kind) => {
    if (!status || !statusText) return
    statusText.textContent = formText(key)
    status.hidden = false
    status.classList.remove('contact-form__status--in')
    void status.offsetWidth
    status.classList.add('contact-form__status--in')
    status.classList.toggle('contact-form__status--error', kind === 'error')
  }

  const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/

  const markInvalid = (input, key) => {
    showStatus(key, 'error')
    input.classList.add('contact-form__field-error')
    input.focus()
    input.addEventListener(
      'input',
      () => input.classList.remove('contact-form__field-error'),
      { once: true }
    )
  }

  const validate = (data) => {
    const checks = [
      ['name', data.name.trim(), 'errName'],
      ['email', data.email.trim(), 'errEmail'],
      ['email', !data.email.trim() || emailRe.test(data.email.trim()), 'errEmailInvalid'],
      ['subject', data.subject.trim(), 'errSubject'],
      ['message', data.message.trim(), 'errMessage'],
    ]
    for (const [name, ok, key] of checks) {
      if (!ok) {
        markInvalid(form.elements[name], key)
        return false
      }
    }
    return true
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()

    const data = Object.fromEntries(new FormData(form))
    if (!validate(data)) return

    const { serviceId, templateId, publicKey } = site.emailjs
    if (!serviceId || !templateId || !publicKey) {
      const body = `${data.name} <${data.email}>\n\n${data.message}`
      location.href = `mailto:${site.email}?subject=${encodeURIComponent(data.subject)}&body=${encodeURIComponent(body)}`
      return
    }

    sendBtn.disabled = true
    sendBtn.classList.add('contact-form__send--loading')
    sendLabel.textContent = formText('sending')
    status.hidden = true
    try {
      const res = await fetch('https://api.emailjs.com/api/v1.0/email/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          service_id: serviceId,
          template_id: templateId,
          user_id: publicKey,
          template_params: {
            nombre: data.name,
            email: data.email,
            mensaje: `[${data.subject}]\n\n${data.message}`,
          },
        }),
      })
      if (!res.ok) throw new Error(await res.text())
      showStatus('success')
      form.reset()
    } catch {
      showStatus('error', 'error')
    } finally {
      sendBtn.disabled = false
      sendBtn.classList.remove('contact-form__send--loading')
      sendLabel.textContent = formText('send')
    }
  })

  // En movil la tarjeta es alta y el dibujo se amplia
  const beamsSvg = document.querySelector('.contact-beams svg')
  const beamsMq = window.matchMedia('(max-width: 640px)')
  const setBeamsAspect = () => {
    beamsSvg?.setAttribute('preserveAspectRatio', beamsMq.matches ? 'xMidYMid slice' : 'xMidYMid meet')
  }
  setBeamsAspect()
  beamsMq.addEventListener('change', setBeamsAspect)
  if (beamsMq.matches) {
    beamsSvg?.querySelector('.contact-beams__animated')?.remove()
    beamsSvg?.querySelector('defs')?.remove()
  }
</script>

<style>
  .contact-form {
    --status-ok: #22c55e;
    --status-err: #ef4444;
  }

  :global(:root[data-theme='light']) .contact-form {
    --status-ok: #15803d;
    --status-err: #b91c1c;
  }

  .contact-form__field input.contact-form__field-error,
  .contact-form__field textarea.contact-form__field-error {
    border-color: color-mix(in srgb, var(--status-err, #ef4444) 70%, transparent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--status-err, #ef4444) 12%, transparent);
  }

  .contact-form__send {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
  }

  .contact-form__spinner {
    display: none;
    width: 1em;
    height: 1em;
    flex: none;
    border: 2px solid color-mix(in srgb, currentColor 30%, transparent);
    border-top-color: currentColor;
    border-radius: 50%;
    animation: contact-spin 0.7s linear infinite;
  }

  .contact-form__send--loading .contact-form__spinner {
    display: inline-block;
  }

  @keyframes contact-spin {
    to {
      transform: rotate(360deg);
    }
  }

  .contact-form .contact-form__status {
    --status-color: var(--status-ok);
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    margin: 0;
    padding: 0.65rem 0.85rem;
    border: 1px solid color-mix(in srgb, var(--status-color) 35%, var(--border));
    border-left: 3px solid var(--status-color);
    border-radius: 10px;
    background: color-mix(in srgb, var(--status-color) 9%, transparent);
    font-family: var(--font-mono);
    font-size: 0.84rem;
    line-height: 1.45;
    color: var(--status-color);
  }

  .contact-form .contact-form__status--error {
    --status-color: var(--status-err);
  }

  .contact-form__status-icon {
    width: 1.05rem;
    height: 1.05rem;
    flex: none;
    margin-top: 0.1em;
  }

  .contact-form__status-icon--err,
  .contact-form__status--error .contact-form__status-icon--ok {
    display: none;
  }

  .contact-form__status--error .contact-form__status-icon--err {
    display: block;
  }

  .contact-form__status--in {
    animation: contact-status-in 0.3s ease both;
  }

  @keyframes contact-status-in {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 640px) {
    .contact-beams .contact-beams__static {
      stroke-opacity: 0.2;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-form__status--in {
      animation: none;
    }

    .contact-form__spinner {
      animation-duration: 1.6s;
    }
  }
</style>

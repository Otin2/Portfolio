---
import { DATA } from '../data.js';
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="wrap footer-inner">
    <div>
      <div class="footer-logo">{DATA.logo.user}<span class="p">.</span>{DATA.logo.tld}</div>
      <div class="footer-meta">© {year} · built with Astro · Lima, PE</div>
    </div>
    <div class="footer-socials">
      <a href={DATA.contact.github}>GitHub</a>
      <a href={DATA.contact.linkedin}>LinkedIn</a>
      <a href={`mailto:${DATA.contact.email}`}>Email</a>
    </div>
  </div>
</footer>
